{
  "name": "style-transfer-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "landing": "npm run dev:frontend",
    "build": "npm --prefix apps/frontend run build && npm --prefix apps/backend run build"
  }
}
